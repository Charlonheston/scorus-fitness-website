---
/**
 * Componente para inyectar Schema.org Structured Data
 * Cada schema se renderiza en su propio <script> tag para que
 * los validadores los muestren como entidades independientes.
 */

export interface Props {
  schema: Record<string, any> | Record<string, any>[];
}

const { schema } = Astro.props;

function ensureContext(obj: Record<string, any>): Record<string, any> {
  if (!obj['@context']) {
    return { '@context': 'https://schema.org', ...obj };
  }
  return obj;
}

const schemas = Array.isArray(schema) ? schema.map(ensureContext) : [ensureContext(schema)];
---

{schemas.map((s) => (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(s, null, 2)}></script>
))}
